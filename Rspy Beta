-- Hàm chuyển đổi đường dẫn Remote thành dạng game:GetService(...):WaitForChild(...)
local function getSafePath(instance)
    local pathParts = {}
    local current = instance

    while current and current ~= game do
        table.insert(pathParts, 1, current.Name)
        current = current.Parent
    end

    local serviceName = pathParts[1]
    if not serviceName then return "game." .. instance.Name end

    -- Khởi tạo chuỗi bằng GetService
    local formattedPath = string.format('game:GetService("%s")', serviceName)
    
    -- Thêm các cấp WaitForChild phía sau
    for i = 2, #pathParts do
        formattedPath = formattedPath .. string.format(':WaitForChild("%s")', pathParts[i])
    end

    return formattedPath
end

-- Tạo Nút Remote hình chữ nhật
local function createLogButton(remoteInstance, method, args)
    if buttonCount >= maxButtons then
        local children = ScrollingFrame:GetChildren()
        for _, child in ipairs(children) do
            if child:IsA("TextButton") then
                child:Destroy()
                buttonCount = buttonCount - 1
                break
            end
        end
    end

    buttonCount = buttonCount + 1

    local isEvent = (method:lower() == "fireserver")
    local tagText = isEvent and "[Event]" or "[Func]"
    local tagColor = isEvent and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 105, 180)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -8, 0, 32)
    btn.BackgroundColor3 = Color3.fromRGB(32, 35, 40)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(45, 48, 55)
    btn.Text = "  " .. tagText .. " " .. remoteInstance.Name
    btn.TextColor3 = tagColor
    btn.Font = Enum.Font.SourceSansSemibold
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = ScrollingFrame

    -- Xử lý thông minh khi Click Sao Chép
    btn.MouseButton1Click:Connect(function()
        local argsTable = {}
        for i, v in pairs(args) do
            if type(v) == "string" then
                table.insert(argsTable, '"' .. tostring(v) .. '"')
            elseif type(v) == "userdata" then
                pcall(function()
                    -- Chuyển đổi các Instance con truyền vào tham số thành đường dẫn an toàn luôn
                    argsTable[i] = getSafePath(v)
                end)
            else
                table.insert(argsTable, tostring(v))
            end
        end
        
        -- Lấy đường dẫn an toàn tuyệt đối của Remote gốc
        local safeRemotePath = getSafePath(remoteInstance)
        local codeToCopy = ""

        if #argsTable > 0 then
            local formattedArgs = table.concat(argsTable, ", ")
            codeToCopy = string.format(
                "local args = {\n    %s\n}\n\n%s:%s(unpack(args))", 
                formattedArgs, safeRemotePath, method
            )
        else
            codeToCopy = string.format("%s:%s()", safeRemotePath, method)
        end
        
        setclipboard(codeToCopy)
        
        -- Hiệu ứng phản hồi trực quan
        btn.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Text = "  ✔️ COPIED PRO CODE!"
        task.wait(0.4)
        btn.BackgroundColor3 = Color3.fromRGB(32, 35, 40)
        btn.TextColor3 = tagColor
        btn.Text = "  " .. tagText .. " " .. remoteInstance.Name
    end)
end

--/ HOOK METAMETHOD LẮNG NGHE
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if self then
        if (method == "FireServer" or method == "fireServer") and self:IsA("RemoteEvent") then
            task.spawn(function()
                createLogButton(self, "FireServer", args)
            end)
        elseif (method == "InvokeServer" or method == "invokeServer") and self:IsA("RemoteFunction") then
            task.spawn(function()
                createLogButton(self, "InvokeServer", args)
            end)
        end
    end
    
    return oldNamecall(self, ...)
end)
